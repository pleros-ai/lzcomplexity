# Include all C++ source files
include modules/core/src/*.cpp
include modules/sa/src/*.cpp
include modules/utils/src/*.cpp

# Include all header files
include modules/core/inc/lz/*.h
include modules/core/inc/lz/*.hpp
include modules/sa/inc/lz/*.h
include modules/utils/inc/lz/*.h

# Include Python binding source files
include python/src/*.cpp
include python/src/inc/*.hpp

# Include CMake files
include CMakeLists.txt
include modules/CMakeLists.txt
include modules/core/CMakeLists.txt
include modules/sa/CMakeLists.txt
include modules/utils/CMakeLists.txt
include python/CMakeLists.txt

# Include patches
include patches/tbb.patch

# Include documentation
include README.md
include LICENSE

# Include build configuration
include pyproject.toml
include setup.py

# Exclude build artifacts
global-exclude *.pyc
global-exclude __pycache__
global-exclude *.so
global-exclude *.dll
global-exclude *.dylib
global-exclude *.pyd
global-exclude .git*
global-exclude .DS_Store
global-exclude *.egg-info
