{
   "tasks": [
      {
         "type": "shell",
         "label": "CMake: configure debug",
         "command": "cmake",
         "args": [
            "-S", "${workspaceFolder}",
            "-B", "${workspaceFolder}/build",
            "-DCMAKE_BUILD_TYPE=Debug",
            "-DCMAKE_INSTALL_PREFIX=../bin",
            "-DLZ_SHARE=ON",
            "-DLZ_PARALLEL_BACKEND=TBB"
         ],
         "problemMatcher": [],
         "detail": "Configure CMake with debug options"
      },
      {
         "type": "shell",
         "label": "CMake: configure release",
         "command": "cmake",
         "args": [
            "-S", "${workspaceFolder}",
            "-B", "${workspaceFolder}/build",
            "-DCMAKE_BUILD_TYPE=Release",
            "-DCMAKE_INSTALL_PREFIX=../bin",
            "-DLZ_SHARE=ON",
            "-DLZ_PARALLEL_BACKEND=TBB"
         ],
         "problemMatcher": [],
         "detail": "Configure CMake with debug options"
      },
      {
         "type": "cmake",
         "label": "CMake: build release",
         "command": "build",
         "targets": [
            "all"
         ],
         "group": "build",
         "problemMatcher": [],
         "detail": "CMake template build task",
         "dependsOn": [
            "CMake: configure release"
         ]
      },
      {
         "type": "cmake",
         "label": "CMake: build debug",
         "command": "build",
         "targets": [
            "all"
         ],
         "group": "build",
         "problemMatcher": [],
         "detail": "CMake template build task",
         "dependsOn": [
            "CMake: configure debug"
         ]
      }
   ],
   "version": "2.0.0"
}